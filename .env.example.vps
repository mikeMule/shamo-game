# =============================================================================
# SHAMO — Production .env (VPS)
# =============================================================================
# Copy to .env on the server. Fill in tokens and DB keys; URLs below are for
# selamdelivery.xyz. After any change → pm2 restart shamo-api. Never commit .env.
# =============================================================================

# ── Server: PORT, API URL, environment ──────────────────────────────────────
# APP_ENV=production → redirects / to /shamo/game, /admin-panel to /shamo/admin
PORT=8002
API_BASE_URL=https://selamdelivery.xyz
APP_ENV=production

# ── Public URLs (same server) ───────────────────────────────────────────────
# User app (Mini App / Telegram):  https://selamdelivery.xyz/shamo/game/index.html
# Admin panel:                     https://selamdelivery.xyz/shamo/admin/login.html

# ── Telegram Bot ───────────────────────────────────────────────────────────
# From @BotFather
TELEGRAM_BOT_TOKEN=8654074069:AAG8mYMIN5K_49926iZ6U2hJPzoG8yac_OY


# ── Mini App URL (HTTPS, used in bot messages) ───────────────────────────────
SHAMO_WEBAPP_URL=https://selamdelivery.xyz/shamo/game/index.html

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Admin Panel ───────────────────────────────────────────────────────────
ADMIN_TOKEN=shamo_admin_2024
ADMIN_USERNAME=admin
ADMIN_PASSWORD=shamo2024

# ── Optional: PostgreSQL ──────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname
