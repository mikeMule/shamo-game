# =============================================================================
# SHAMO — Environment Variables (Example)
# =============================================================================
# Copy this file to .env and put your real values in .env. Never commit .env.
# Every variable below is read by api.py, bot.py, or db.py; game uses API_BASE_URL,
# SUPABASE_URL, SUPABASE_ANON_KEY via /api/public/env.js (from this .env).
# =============================================================================

# ── Server: PORT, API URL, and environment ───────────────────────────────────
# Used by: api.py (port + redirects + /api/public/env.js), bot.py (API_BASE_URL),
#          ecosystem.config.js (PORT), admin/game (API_BASE_URL via env.js)
# PORT: port uvicorn listens on (e.g. 8001 local, 8002 production)
# API_BASE_URL: public origin of this server, no trailing slash
#   Local: http://localhost:8001   Production: https://selamdelivery.xyz
# APP_ENV: local = redirects / to /game, /admin-panel to /admin. production/vps = redirects to /shamo/game, /shamo/admin
PORT=8001
API_BASE_URL=http://localhost:8001
APP_ENV=local

# ── Telegram Bot ───────────────────────────────────────────────────────────
# Used by: api.py (avatar/telegram), bot.py. From @BotFather
TELEGRAM_BOT_TOKEN=8763415789:AAHCPb8At4xa-C11LlPUU2-7bhIvWjmeJ44


# ── Mini App URL ───────────────────────────────────────────────────────────
# Used by: bot.py (link sent in messages; must be HTTPS for Telegram)
SHAMO_WEBAPP_URL=https://wigglier-rose-nonplussedly.ngrok-free.dev/game/index.html

# ── Supabase ───────────────────────────────────────────────────────────────
# Used by: api.py (all DB), bot.py (broadcast), game (SUPABASE_URL + ANON via env.js)
# Copy from Supabase dashboard; never commit real keys.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Admin Panel ───────────────────────────────────────────────────────────
# Used by: api.py (login and X-Admin-Token)
ADMIN_TOKEN=shamo_admin_2024
ADMIN_USERNAME=admin
ADMIN_PASSWORD=shamo2024

# ── Optional: direct PostgreSQL ─────────────────────────────────────────────
# Used by: db.py only (optional if using supabase-py for all DB)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=
